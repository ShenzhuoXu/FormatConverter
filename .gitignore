# -----------------------------------------------------------------------------
# 1. 项目特定忽略
# -----------------------------------------------------------------------------

# 忽略存放原始 PDF 文件的目录，这些是输入数据，不应纳入版本控制
# 这也可以保护隐私
/pdfs/

# 忽略由 pymupdf4llm 生成的 Markdown 文件
/mds/

# 忽略由 marker-pdf 生成的输出目录
/output_markdown/

# 忽略 Markdown 清理脚本生成的备份文件
*.bak.md


# -----------------------------------------------------------------------------
# 2. Python 通用忽略
# -----------------------------------------------------------------------------

# Python 字节码和缓存
__pycache__/
*.pyc
*.pyo
*.pyd

# Python 虚拟环境 (常见名称)
# 如果你的虚拟环境文件夹名称不同，请添加到这里
.venv/
venv/
env/
ENV/
.env/

# 打包和分发目录
dist/
build/
*.egg-info/
*.egg

# 单元测试和覆盖率报告
.pytest_cache/
htmlcov/
.coverage
.coverage.*


# -----------------------------------------------------------------------------
# 3. 操作系统和编辑器特定忽略
# -----------------------------------------------------------------------------

# 操作系统生成的文件
.DS_Store      # macOS
Thumbs.db      # Windows
ehthumbs.db    # Windows

# 编辑器/IDE 配置文件
.idea/         # JetBrains IDEs (如 PyCharm)
.vscode/       # Visual Studio Code.idea/
